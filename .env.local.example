# Frontend environment variables
# Copy this to .env.local and set your values

# Design preview: use mock catalog (no backend required). Set to "false" when API is ready.
NEXT_PUBLIC_USE_MOCK_CATALOG=true

BACKEND_URL=http://localhost:5001

# Use static mock catalog on /shop and /product (set to false when backend is ready)
NEXT_PUBLIC_USE_MOCK_CATALOG=true
